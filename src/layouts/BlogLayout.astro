---
const { title } = Astro.props;
import { ViewTransitions } from 'astro:transitions'
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <ViewTransitions />
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="navbar">
      <div class="container nav-flex">
        <h1 class="logo">Mi<span>Blog</span></h1>
        <nav>
          <a href="/">Inicio</a>
          <a href="/blog" class="active">Blog</a>
        </nav>
      </div>
    </header>



<main>
  <slot />
</main>

    <footer class="footer">
      <p>© 2026 - Diseño Vanguardista con Astro</p>
    </footer>
  </body>
</html>

<style is:global>


  :root {
    --primary: #0061ff;
    --text: #1f2937;
    --light: #f3f4f6;
    --white: #ffffff;
    --shadow: 0 4px 20px rgba(0,0,0,0.08);
  }

 body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  background-color: #f8fafc; /* Un gris muy claro, estilo moderno */
  color: var(--text);
}

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem;
  }

  .navbar {
    background: var(--white);
    border-bottom: 1px solid #e5e7eb;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .footer {
    width: 100%;
    padding: 3rem 0;
    margin-top: 4rem;
    border-top: 1px solid #e5e7eb;
    background: var(--white);
    
    /* ESTO CENTRA EL CONTENIDO */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .footer p {
    margin: 0;
    color: #6b7280;
    font-size: 0.9rem;
    font-weight: 500;
  }
  
  .nav-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2rem;
  }

  .logo { font-weight: 900; font-size: 1.5rem; margin: 0; }
  .logo span { color: var(--primary); }

  nav a {
    text-decoration: none;
    color: var(--text);
    margin-left: 1.5rem;
    font-weight: 600;
  }

  nav a.active { color: var(--primary); }
</style>