---
const { post } = Astro.props;
---
<article class="card">
  <div class="image-wrapper">
    <img src={post.data.image} alt={post.data.title} />
    {post.data.category && <span class="category-tag">{post.data.category}</span>}
  </div>
  
  <div class="card-body">
    <time>{post.data.pubDate.toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}</time>
    <h3><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
    <p>{post.data.description}</p>
    <a href={`/blog/${post.slug}`} class="read-more">Leer artículo →</a>
  </div>
</article>

<style>
  .card {
    background: #fff;
    border-radius: 20px;
    border: 1px solid #eee;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    border-color: #0061ff;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 220px; /* Esto evita que la imagen sea gigante */
    overflow: hidden;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Recorta la imagen para que encaje perfecto */
    transition: transform 0.5s ease;
  }

  .card:hover img {
    transform: scale(1.1);
  }

  .category-tag {
    position: absolute;
    top: 15px;
    left: 15px;
    background: #0061ff;
    color: white;
    padding: 4px 12px;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  time { font-size: 0.8rem; color: #888; margin-bottom: 0.5rem; }

  h3 { margin: 0; font-size: 1.25rem; line-height: 1.3; }
  h3 a { text-decoration: none; color: #111; }

  p { font-size: 0.9rem; color: #555; line-height: 1.6; margin: 1rem 0; }

  .read-more {
    margin-top: auto;
    color: #0061ff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.85rem;
  }
</style>